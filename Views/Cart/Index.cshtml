@model DonutShop.Models.Cart
@{
    ViewData["Title"] = "Your Cart";
}

<h1 class="mb-4">🛒 Your Cart</h1>

@if (Model.Items.Count == 0)
{
    <div class="alert alert-info">
        Your cart is empty. <a asp-controller="Home" asp-action="Index">Browse the menu</a>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Donut</th>
                    <th class="text-end">Price</th>
                    <th class="text-center" style="width:160px;">Qty</th>
                    <th class="text-end">Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td class="text-end">@item.Price.ToString("C")</td>
                        <td class="text-center">
                            <form asp-action="Update" method="post" class="d-inline-flex gap-2 justify-content-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.DonutId" />
                                <input type="number" name="quantity" value="@item.Quantity" min="0"
                                       class="form-control form-control-sm" style="width:70px;" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Update</button>
                            </form>
                        </td>
                        <td class="text-end">@item.LineTotal.ToString("C")</td>
                        <td class="text-end">
                            <form asp-action="Remove" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.DonutId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3" class="text-end">Total</th>
                    <th class="text-end">@Model.Total.ToString("C")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="d-flex justify-content-between">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">← Keep shopping</a>
        <a asp-controller="Checkout" asp-action="Index" class="btn btn-pink btn-lg">Checkout →</a>
    </div>
}

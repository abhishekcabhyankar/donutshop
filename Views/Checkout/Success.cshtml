@model DonutShop.Models.CheckoutResultViewModel
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="text-center py-5">
    <div class="display-1">🎉🍩</div>
    <h1 class="mt-3">Thank you for your order!</h1>
    <p class="lead">Your donuts are on their way.</p>

    <div class="card mx-auto mt-4 shadow-sm" style="max-width: 420px;">
        <div class="card-body text-start">
            <div class="d-flex justify-content-between">
                <span class="text-muted">Amount charged</span>
                <strong>@Model.AmountCharged.ToString("C")</strong>
            </div>
            <div class="d-flex justify-content-between mt-2">
                <span class="text-muted">Transaction ID</span>
                <strong>@Model.TransactionId</strong>
            </div>
            <div class="d-flex justify-content-between mt-2">
                <span class="text-muted">Status</span>
                <span class="badge bg-success">@Model.Message</span>
            </div>
        </div>
    </div>

    <a asp-controller="Home" asp-action="Index" class="btn btn-pink btn-lg mt-4">Order more donuts</a>
</div>
